        A3[Search index]
        A4[Metric and feature computation]
        A5[Model registry and inference]
        A6[Experiment assignment and exposure]
        A7[Guardrail monitoring]
    end

    subgraph R[Governed serving and learning]
        R1[Metric and Engineering Change APIs]
        R2[Evidence explorer]
        R3[Experiment console]
        R4[Decision workbench]
        R5[Practitioner and executive products]
        R6[Evidence, metric, study, and decision registries]
    end

