{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/geekychris/-Engineering-Intelligence/blob/main/schemas/publication-manifest.schema.json",
  "title": "Engineering Intelligence Publication Manifest",
  "description": "Schema for build/manifest.json generated by the Engineering Intelligence publication pipeline.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "title",
    "build_mode",
    "publication_time",
    "source_date_epoch",
    "source_commit",
    "files",
    "diagram_count"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "title": {
      "const": "Engineering Intelligence"
    },
    "build_mode": {
      "enum": ["all", "html", "pdf", "validate"]
    },
    "publication_time": {
      "type": "string",
      "format": "date-time"
    },
    "source_date_epoch": {
      "type": "integer",
      "minimum": 0
    },
    "source_commit": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "files": {
      "type": "array",
      "minItems": 1,
      "maxItems": 2,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/artifact"
      }
    },
    "diagram_count": {
      "type": "integer",
      "minimum": 0
    }
  },
  "$defs": {
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "bytes", "sha256"],
      "properties": {
        "name": {
          "enum": [
            "engineering-intelligence.html",
            "engineering-intelligence.pdf"
          ]
        },
        "bytes": {
          "type": "integer",
          "minimum": 0
        },
        "sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        }
      }
    }
  }
}
